/**\n * Environment configuration example\n * Copy to .env.local and fill in actual values\n */\n\n# MediaPipe Configuration\nNEXT_PUBLIC_MEDIAPIPE_WASM_PATH=/wasm\nNEXT_PUBLIC_MEDIAPIPE_MODEL=face_landmarker.task\n\n# Feature Flags\nNEXT_PUBLIC_ENABLE_SYMMETRY_ANALYSIS=true\nNEXT_PUBLIC_ENABLE_PDF_EXPORT=true\nNEXT_PUBLIC_ENABLE_HISTORY=false\n\n# Analytics (optional)\nNEXT_PUBLIC_ANALYTICS_ID=\n"
